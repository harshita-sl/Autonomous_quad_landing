<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="inertial_macros.xacro"/>

    <!-- Camera Properties -->
    <xacro:property name="camera_mass" value="0.01"/>
    <xacro:property name="camera_width" value="0.05"/>
    <xacro:property name="camera_height" value="0.02"/>
    <xacro:property name="camera_depth" value="0.02"/>
    
    <!-- Camera offset from base_link (downward facing) -->
    <xacro:property name="camera_x_offset" value="0.1"/>
    <xacro:property name="camera_y_offset" value="0.0"/>
    <xacro:property name="camera_z_offset" value="-0.05"/>

    <!-- Colors -->
    <material name="red">
        <color rgba="0.8 0.0 0.0 1.0"/>
    </material>

    <material name="camera_black">
        <color rgba="0.2 0.2 0.2 1.0"/>
    </material>

    <!-- Camera Macro -->
    <xacro:macro name="depth_camera" params="prefix parent_link *origin">
        
        <!-- Camera Link -->
        <link name="${prefix}_camera_link">
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <box size="${camera_depth} ${camera_width} ${camera_height}"/>
                </geometry>
                <material name="camera_black"/>
            </visual>

            <collision>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <box size="${camera_depth} ${camera_width} ${camera_height}"/>
                </geometry>
            </collision>

            <xacro:inertial_box mass="${camera_mass}" 
                                x="${camera_depth}" 
                                y="${camera_width}" 
                                z="${camera_height}">
                <origin xyz="0 0 0" rpy="0 0 0"/>
            </xacro:inertial_box>
        </link>

        <!-- Camera Joint (Fixed to parent, pointing downward) -->
        <joint name="${prefix}_camera_joint" type="fixed">
            <parent link="${parent_link}"/>
            <child link="${prefix}_camera_link"/>
            <xacro:insert_block name="origin"/>
        </joint>

        <!-- Camera Optical Frame (ROS convention: z forward, x right, y down) -->
        <link name="${prefix}_camera_optical_frame"/>

        <joint name="${prefix}_camera_optical_joint" type="fixed">
            <parent link="${prefix}_camera_link"/>
            <child link="${prefix}_camera_optical_frame"/>
            <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
        </joint>

        <!-- Gazebo Camera Plugin -->
        <gazebo reference="${prefix}_camera_link">
            <material>Gazebo/Red</material>
            
            <sensor name="${prefix}_camera" type="depth">
                <update_rate>30.0</update_rate>
                <visualize>true</visualize>
                
                <camera name="${prefix}_camera">
                    <horizontal_fov>1.047198</horizontal_fov>
                    <image>
                        <width>640</width>
                        <height>480</height>
                        <format>R8G8B8</format>
                    </image>
                    <clip>
                        <near>0.05</near>
                        <far>10.0</far>
                    </clip>
                    <noise>
                        <type>gaussian</type>
                        <mean>0.0</mean>
                        <stddev>0.007</stddev>
                    </noise>
                </camera>
                
                <plugin name="${prefix}_camera_controller" filename="libgazebo_ros_camera.so">
                    <ros>
                        <namespace>iris</namespace>
                        <remapping>${prefix}_camera/image_raw:=camera/image_raw</remapping>
                        <remapping>${prefix}_camera/image_depth:=camera/depth/image_raw</remapping>
                        <remapping>${prefix}_camera/camera_info:=camera/camera_info</remapping>
                        <remapping>${prefix}_camera/points:=camera/points</remapping>
                    </ros>
                    <camera_name>${prefix}_camera</camera_name>
                    <frame_name>${prefix}_camera_optical_frame</frame_name>
                    <hack_baseline>0.07</hack_baseline>
                    <min_depth>0.05</min_depth>
                    <max_depth>10.0</max_depth>
                </plugin>
            </sensor>
        </gazebo>

    </xacro:macro>

</robot>